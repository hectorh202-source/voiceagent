# Non-secret infra config only. All credentials (ElevenLabs, ServiceTitan, etc.)
# are entered through the /settings web page after the server is running,
# and stored encrypted in the local SQLite database — not here.

PORT=3000
DATABASE_PATH=./data/app.db

# ENCRYPTION_KEY is a real exception to the "no credentials here" rule above —
# it's the deployment's own master key, not a business credential, and it
# structurally can't live inside the encrypted store it protects (chicken-and-
# egg). Optional: if unset, the app falls back to a key file stored alongside
# the database (a real security gap for backups — see
# docs/sqlite-storage.md#the-encryption-key-itself). Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ENCRYPTION_KEY=
